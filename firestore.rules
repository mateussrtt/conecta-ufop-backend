rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.role == 'admin';
    }

		match /usuarios/{userId} {
  		allow read: if request.auth != null;
  		allow write: if request.auth != null && request.auth.uid == userId;
		}

    match /caronas/{caronaId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.motoristaId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.motoristaId == request.auth.uid;
    }

    match /app/{document=**} {
      allow read: if true;
    }
  }
}